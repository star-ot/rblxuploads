# Studio Vault requires no environment variables for core functionality.
#
# Configure your Roblox Open Cloud API key and creator ID in the app UI.
# Settings are stored in browser localStorage only.
#
# Optional — override the canonical site URL used for SEO metadata, sitemap,
# and Open Graph images (defaults to https://uploader.starvsk.dev):
# NEXT_PUBLIC_SITE_URL=https://uploader.starvsk.dev
