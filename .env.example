# Studio Vault — environment variables
#
# Core uploads work with zero env vars. Credentials live in browser localStorage.
# Use these when self-hosting for production SEO, audit logging, and CORS lockdown.

# --- Public (embedded in client bundle) ---

# Canonical site URL for SEO, sitemap, and Open Graph.
# On Vercel, leave unset to auto-detect VERCEL_URL at build time.
NEXT_PUBLIC_SITE_URL=https://vault.yourstudio.com

# Client-visible hint that audit logging is on (mirrors RBLXUPLOADS_AUDIT_LOG)
NEXT_PUBLIC_RBLXUPLOADS_AUDIT_LOG=0

# --- Server-only ---

# HTTP port (default 3000)
# PORT=3000

# Structured JSON audit log per upload (never logs API keys or file bytes)
RBLXUPLOADS_AUDIT_LOG=0

# Optional file path for audit logs (stdout if unset)
# RBLXUPLOADS_AUDIT_LOG_PATH=/var/log/studio-vault/audit.jsonl

# Trust X-Forwarded-* and X-Studio-Vault-Actor for audit attribution
RBLXUPLOADS_TRUST_PROXY=1

# Comma-separated browser origins allowed to call /api/upload
# RBLXUPLOADS_ALLOWED_ORIGINS=https://vault.yourstudio.com

# Verbose upload debug logs (not for production)
# RBLXUPLOADS_DEBUG=0

# Optional default webhook for batch-complete notifications (browser can override in Settings)
# RBLXUPLOADS_WEBHOOK_URL=https://hooks.slack.com/services/...
# RBLXUPLOADS_WEBHOOK_SECRET=

# Prometheus metrics at GET /api/metrics (protect in production with token below)
# RBLXUPLOADS_METRICS_PUBLIC=0
# RBLXUPLOADS_METRICS_TOKEN=

# CI policy defaults for studio-vault validate
# STUDIO_VAULT_NAME_PATTERN=^UI_[A-Za-z0-9_]+$
# STUDIO_VAULT_MAX_NAME_LENGTH=50

# --- CLI / CI only (never on the Studio Vault web server) ---

# ROBLOX_OPEN_CLOUD_KEY=
# ROBLOX_CREATOR_ID=
# ROBLOX_CREATOR_TYPE=user
